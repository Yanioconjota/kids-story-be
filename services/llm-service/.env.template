PORT=8002

# Provider: mock | openai | anthropic | ollama
LLM_PROVIDER=mock

# Model name (leave blank to use the provider default)
# openai default:    gpt-4o-mini
# anthropic default: claude-3-5-haiku-20241022
# ollama default:    llama3.2
LLM_MODEL=

# API key (required for openai and anthropic; not used for mock/ollama)
LLM_API_KEY=

# Base URL override
# Ollama example: http://ollama:11434/v1
# OpenAI-compatible proxy: https://your-proxy.example.com/v1
LLM_BASE_URL=
